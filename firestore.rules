rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'uiuvccup@gmail.com';
    }
    
    // Helper function to check if user is team owner
    function isTeamOwner() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'team_owner';
    }
    
    // Teams collection - read: all, write: admin only
    match /teams/{teamId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Players collection - read: all, write: admin only
    match /players/{playerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Users collection - read: authenticated, write: admin only
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }
    
    // Auction bids collection - read: all, write: admin only
    match /auction_bids/{bidId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Auctions collection - read: all, write: admin only
    match /auctions/{auctionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Bids collection - read: all, write: admin only
    match /bids/{bidId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Default rule - deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
