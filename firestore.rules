rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    function isTeamOwner() {
      return request.auth != null && request.auth.token.role == 'team_owner';
    }

    function teamOwnerTeamName() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamName;
    }
    
    // Teams collection - read: all, write: admin only
    match /teams/{teamId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Players collection - read: all, write: admin only
    match /players/{playerId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isTeamOwner()
          && resource.data.team == teamOwnerTeamName()
          && request.resource.data.team == resource.data.team
          && request.resource.data.soldPrice == resource.data.soldPrice);
    }

    match /cricket-teams/{teamId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cricket-players/{playerId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isTeamOwner()
          && resource.data.team == teamOwnerTeamName()
          && request.resource.data.team == resource.data.team
          && request.resource.data.soldPrice == resource.data.soldPrice);
    }
    
    // Users collection - read: self or admin, write: self (limited) or admin
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }
    
    // Auction bids collection - read: all, write: admin only
    match /auction_bids/{bidId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Auctions collection - read: all, write: admin only
    match /auctions/{auctionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Bids collection - read: all, write: admin only
    match /bids/{bidId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Default rule - deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
